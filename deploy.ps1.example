$ErrorActionPreference = "Stop"
Set-StrictMode -Version Latest

# --- [설정 구간] --- 아래 값을 자신의 환경에 맞게 수정 후 deploy.ps1로 복사하세요 ---
$PROFILE_NAME = "your-aws-profile"           # AWS CLI 프로필명
$REGION = "ap-northeast-2"                   # AWS 리전
$S3_BUCKET = "s3://your-bucket/your-path"    # S3 배포 경로
$ZIP_NAME = "license-manager.zip"            # 압축 파일명 (변경 불필요)
$EC2_ID = "i-0xxxxxxxxxxxx"                  # EC2 인스턴스 ID
$REMOTE_DIR = "/home/ssm-user/app"           # EC2 내 배포 디렉토리
$APP_NAME = "license-manager"                # 앱 디렉토리명 (변경 불필요)

# --- [유틸리티 함수] ---
function Log($msg)     { Write-Host "[$(Get-Date -Format 'HH:mm:ss')] $msg" }
function Success($msg) { Write-Host "[$(Get-Date -Format 'HH:mm:ss')] $msg" -ForegroundColor Green }
function Warn($msg)    { Write-Host "[$(Get-Date -Format 'HH:mm:ss')] $msg" -ForegroundColor Yellow }
function Fail($msg)    { Write-Host "[$(Get-Date -Format 'HH:mm:ss')] $msg" -ForegroundColor Red }

function Invoke-OrFail([scriptblock]$Script, [string]$ErrorMessage) {
    & $Script
    if ($LASTEXITCODE -ne 0) { Fail $ErrorMessage; exit 1 }
}

# ============================================================
# [1/3] Git Push
# ============================================================
Log "=== [1/3] Git 작업 시작 ==="

$lockFile = Join-Path (Get-Location) ".git/index.lock"
if (Test-Path $lockFile) {
    Warn "Git Lock 파일 감지 — 제거 시도..."
    try { Remove-Item $lockFile -Force -ErrorAction Stop }
    catch { Fail "Lock 파일 제거 실패. VS Code 등 다른 Git 프로그램을 종료하세요."; exit 1 }
}

$hasChanges = (git status --porcelain)
if (-not [string]::IsNullOrWhiteSpace($hasChanges)) {
    Log "변경사항 감지. 커밋을 진행합니다."
    Invoke-OrFail { git add -A } "git add 실패"
    $commitMsg = Read-Host "커밋 메시지 입력 (엔터 시 'deploy')"
    if ([string]::IsNullOrWhiteSpace($commitMsg)) { $commitMsg = "deploy" }
    Invoke-OrFail { git commit -m $commitMsg } "git commit 실패"
}
else {
    Warn "커밋할 변경사항 없음."
}

# master 브랜치 확인
$currentBranch = (git branch --show-current)
if ($currentBranch -ne "master") {
    Fail "현재 브랜치가 '$currentBranch'입니다. master 브랜치에서 실행하세요: git checkout master"
    exit 1
}

Invoke-OrFail { git fetch origin } "git fetch 실패"
Invoke-OrFail { git pull origin master } "git pull 실패 (충돌 시 수동 해결 필요)"
Invoke-OrFail { git push origin master } "git push 실패"
Success "Git 동기화 완료"

# ============================================================
# [2/3] S3 업로드 (소스 패키지)
# ============================================================
Log "=== [2/3] S3 업로드 준비 ==="
$zipPath = Join-Path $env:TEMP $ZIP_NAME
if (Test-Path $zipPath) { Remove-Item $zipPath -Force }

Log "압축 파일 생성 중 (git archive)..."
Invoke-OrFail { git archive --format=zip HEAD -o $zipPath } "git archive 실패"

Log "S3 업로드 중..."
Invoke-OrFail {
    aws s3 cp $zipPath "$S3_BUCKET/$ZIP_NAME" --profile $PROFILE_NAME --region $REGION
} "S3 업로드 실패"

Remove-Item $zipPath -ErrorAction SilentlyContinue
Success "S3 업로드 완료: $S3_BUCKET/$ZIP_NAME"

# ============================================================
# [3/3] EC2 배포 (SSM RunCommand)
#   안전 배포: 디스크 점검 2회 + DB 보호 + 단계별 중단
# ============================================================
Log "=== [3/3] EC2 배포 시작 (SSM RunCommand) ==="

$deployCommands = @(
    "set -e",

    # ── [1/7] 사전 점검: Docker 데몬 ──
    "echo '=== [1/7] 사전 점검 ==='",
    "if ! sudo docker info > /dev/null 2>&1; then echo 'ABORT: Docker 데몬이 실행 중이 아닙니다'; exit 1; fi",
    "echo 'Docker 데몬 OK'",

    # ── [2/7] 사전 점검: 디스크 공간 (최소 2GB) ──
    "echo '=== [2/7] 디스크 공간 점검 ==='",
    "AVAIL_KB=`$(df / --output=avail | tail -1 | tr -d ' ')",
    "AVAIL_MB=`$(( AVAIL_KB / 1024 ))",
    "echo ""디스크 여유: `${AVAIL_MB}MB""",
    "if [ `$AVAIL_KB -lt 2097152 ]; then echo ""ABORT: 디스크 여유 부족 (`${AVAIL_MB}MB < 2048MB). 배포 중단.""; exit 1; fi",
    "echo 'PASS: 디스크 2GB 이상 여유'",

    # ── [3/7] 사전 점검: 스왑 ──
    "echo '=== [3/7] 스왑 점검 ==='",
    "free -h",
    "if [ ! -f /swapfile ]; then sudo dd if=/dev/zero of=/swapfile bs=128M count=16 && sudo chmod 600 /swapfile && sudo mkswap /swapfile && sudo swapon /swapfile && echo '스왑 신규 설정 완료'; else echo '스왑 기존 설정 확인됨'; fi",

    # ── [4/7] 소스코드 다운로드 (임시 디렉토리에 풀기 — 기존 코드 보존) ──
    "echo '=== [4/7] S3에서 소스코드 다운로드 ==='",
    "cd $REMOTE_DIR",
    "aws s3 cp $S3_BUCKET/$ZIP_NAME .",
    "sudo rm -rf ${APP_NAME}-new",
    "sudo mkdir -p ${APP_NAME}-new && sudo chown -R ssm-user:ssm-user ${APP_NAME}-new",
    "unzip -q $ZIP_NAME -d ${APP_NAME}-new && rm $ZIP_NAME",
    "echo 'PASS: 새 소스코드 준비 완료 (${APP_NAME}-new/)'",

    # ── [5/7] 앱 컨테이너만 중지 (postgres는 계속 실행) ──
    "echo '=== [5/7] 앱 컨테이너 교체 (DB 유지) ==='",
    "echo '--- DB 볼륨 보호 확인 ---'",
    "if sudo docker volume ls -q | grep -q postgres_data; then echo 'postgres_data 볼륨 존재 확인'; else echo '(최초 배포: 볼륨 아직 없음)'; fi",
    "if [ -d $REMOTE_DIR/$APP_NAME ]; then cd $REMOTE_DIR/$APP_NAME && sudo docker-compose stop app || true && sudo docker-compose rm -f app || true && echo 'PASS: 앱 컨테이너 중지됨 (postgres 유지)'; else echo '(최초 배포: 기존 앱 없음)'; fi",

    # 앱 이미지만 정리 (postgres 이미지 보존!)
    "echo '--- 앱 이미지 정리 (postgres 이미지 보존) ---'",
    "sudo docker images --filter reference='*license-manager*' -q | xargs -r sudo docker rmi -f 2>/dev/null || true",
    "sudo docker builder prune -f 2>/dev/null || true",

    # 기존 코드 → backup, 새 코드 → 현재로 교체
    "cd $REMOTE_DIR",
    "sudo rm -rf ${APP_NAME}-backup",
    "if [ -d $APP_NAME ]; then sudo mv $APP_NAME ${APP_NAME}-backup && echo '기존 코드 backup 완료'; fi",
    "sudo mv ${APP_NAME}-new $APP_NAME",
    "echo 'PASS: 소스코드 교체 완료'",

    # ── [6/7] 디스크 재확인 후 Docker 빌드 ──
    "echo '=== [6/7] Docker 빌드 (디스크 재확인) ==='",
    "AVAIL_KB=`$(df / --output=avail | tail -1 | tr -d ' ')",
    "AVAIL_MB=`$(( AVAIL_KB / 1024 ))",
    "echo ""빌드 전 디스크 여유: `${AVAIL_MB}MB""",
    "if [ `$AVAIL_KB -lt 1048576 ]; then echo ""ABORT: 빌드에 필요한 디스크 부족 (`${AVAIL_MB}MB < 1024MB). postgres는 계속 실행 중 (DB 안전).""; echo '롤백: sudo mv ${APP_NAME}-backup ${APP_NAME}'; exit 1; fi",
    "cd $REMOTE_DIR/$APP_NAME",
    "sudo docker-compose build app",
    "echo 'PASS: Docker 빌드 성공'",

    # ── [7/7] 앱 시작 + 검증 ──
    "echo '=== [7/7] 앱 시작 + 검증 ==='",
    "sudo docker-compose up -d",
    "sleep 5",
    "sudo docker-compose ps",
    "echo ''",

    # DB 볼륨 최종 확인
    "if sudo docker volume ls -q | grep -q postgres_data; then echo 'DB 볼륨 정상'; else echo 'WARNING: postgres_data 볼륨 없음'; fi",

    # 앱 헬스체크 (최대 30초)
    "echo '--- 앱 헬스체크 ---'",
    "for i in 1 2 3 4 5 6; do STATUS=`$(curl -s -o /dev/null -w '%{http_code}' http://localhost:8080/login || echo '000'); if [ `$STATUS = '200' ]; then echo ""앱 정상 응답 (HTTP `$STATUS)""; break; fi; echo ""[`$i/6] 앱 응답 대기... (HTTP `$STATUS)""; sleep 5; done",

    # backup 정리
    "sudo rm -rf $REMOTE_DIR/${APP_NAME}-backup 2>/dev/null || true",
    "echo '배포 완료'"
) | ConvertTo-Json -Compress

$ssmParams = "{`"commands`":$deployCommands}"

# SSM 명령 전송
Log "SSM 명령 전송 중..."
$commandId = aws ssm send-command `
    --instance-ids $EC2_ID `
    --document-name "AWS-RunShellScript" `
    --parameters $ssmParams `
    --timeout-seconds 600 `
    --query "Command.CommandId" `
    --output text `
    --profile $PROFILE_NAME `
    --region $REGION 2>&1

if ($LASTEXITCODE -ne 0) {
    Fail "SSM 명령 전송 실패: $commandId"
    exit 1
}

Success "SSM 명령 전송됨: $commandId"
Log "배포 완료 대기 중... (최대 10분)"

# 배포 완료 대기 (15초 간격, 최대 40회 = 10분)
$maxAttempts = 40
for ($i = 1; $i -le $maxAttempts; $i++) {
    Start-Sleep -Seconds 15

    $status = aws ssm get-command-invocation `
        --command-id $commandId `
        --instance-id $EC2_ID `
        --query "Status" `
        --output text `
        --profile $PROFILE_NAME `
        --region $REGION 2>&1

    if ($LASTEXITCODE -ne 0) {
        Warn "[$i/$maxAttempts] 상태 조회 실패: $status"
        continue
    }

    Log "[$i/$maxAttempts] 상태: $status"

    if ($status -eq "Success") {
        $output = aws ssm get-command-invocation `
            --command-id $commandId `
            --instance-id $EC2_ID `
            --query "StandardOutputContent" `
            --output text `
            --profile $PROFILE_NAME `
            --region $REGION 2>$null
        if ($output) {
            Write-Host ""
            Write-Host "--- EC2 배포 로그 ---" -ForegroundColor DarkGray
            Write-Host $output
            Write-Host "---------------------" -ForegroundColor DarkGray
        }
        Write-Host ""
        Success "=== 배포 완료 ==="
        Write-Host ""
        Write-Host "  확인: http://<EC2_PUBLIC_IP>:8080" -ForegroundColor Cyan
        Write-Host "  로그: aws ssm start-session --target $EC2_ID --region $REGION --profile $PROFILE_NAME" -ForegroundColor DarkGray
        Write-Host "        sudo docker-compose -f $REMOTE_DIR/$APP_NAME/docker-compose.yml logs -f app --tail 30" -ForegroundColor DarkGray
        Write-Host ""
        exit 0
    }
    elseif ($status -eq "Failed" -or $status -eq "TimedOut" -or $status -eq "Cancelled") {
        $errOutput = aws ssm get-command-invocation `
            --command-id $commandId `
            --instance-id $EC2_ID `
            --query "StandardErrorContent" `
            --output text `
            --profile $PROFILE_NAME `
            --region $REGION 2>$null
        if ($errOutput) {
            Write-Host ""
            Write-Host "--- EC2 에러 로그 ---" -ForegroundColor Red
            Write-Host $errOutput
            Write-Host "---------------------" -ForegroundColor Red
        }
        Fail "배포 실패: $status"
        Write-Host ""
        Warn "수동 확인 방법:"
        Write-Host "  aws ssm start-session --target $EC2_ID --region $REGION --profile $PROFILE_NAME" -ForegroundColor White
        Write-Host "  sudo docker-compose -f $REMOTE_DIR/$APP_NAME/docker-compose.yml logs app --tail 50" -ForegroundColor White
        exit 1
    }
}

Fail "배포 타임아웃 (10분 초과)"
exit 1
