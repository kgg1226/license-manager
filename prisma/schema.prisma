// [2026-03-04] MemberStatus/RenewalStatus enum 추가, OrgUnit sortOrder/updatedAt, Employee orgUnitId/status/offboardingUntil 통합,
//              License renewal 필드, LicenseRenewalHistory/LicenseOwner/NotificationLog 신규, AuditLog actorType/actorId, User mustChangePassword

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 Int       @id @default(autoincrement())
  username           String    @unique
  password           String
  role               Role      @default(USER)
  isActive           Boolean   @default(true)
  mustChangePassword Boolean   @default(false)
  createdAt          DateTime  @default(now())
  sessions           Session[]
}

model Session {
  id        String   @id
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model License {
  id                 Int                    @id @default(autoincrement())
  name               String                 @unique
  key                String?
  licenseType        LicenseType            @default(KEY_BASED)
  totalQuantity      Int
  price              Float?
  purchaseDate       DateTime
  expiryDate         DateTime?
  noticePeriodDays   Int?
  adminName          String?
  description        String?
  paymentCycle       PaymentCycle?
  quantity           Int?
  unitPrice          Float?
  currency           Currency               @default(KRW)
  exchangeRate       Float                  @default(1.0)
  isVatIncluded      Boolean                @default(false)
  totalAmountForeign Float?
  totalAmountKRW     Float?
  renewalDate        DateTime?
  renewalDateManual  DateTime?
  renewalStatus      RenewalStatus          @default(BEFORE_RENEWAL)
  parentId           Int?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  parent             License?               @relation("LicenseHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children           License[]              @relation("LicenseHierarchy")
  assignments        Assignment[]
  groupMembers       LicenseGroupMember[]
  seats              LicenseSeat[]
  renewalHistories   LicenseRenewalHistory[]
  owners             LicenseOwner[]
  notificationLogs   NotificationLog[]
  assetLinks         AssetLicenseLink[]

  @@index([parentId])
}

model Employee {
  id               Int           @id @default(autoincrement())
  name             String
  department       String?
  email            String?       @unique
  title            String?
  companyId        Int?
  orgUnitId        Int?
  status           MemberStatus  @default(ACTIVE)
  offboardingUntil DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  assignments      Assignment[]
  assets           Asset[]
  assetAssignmentHistories AssetAssignmentHistory[]
  company          OrgCompany?   @relation(fields: [companyId], references: [id])
  orgUnit          OrgUnit?      @relation("OrgMembers", fields: [orgUnitId], references: [id])

  @@index([orgUnitId])
  @@index([status])
}

// 회사 단위
model OrgCompany {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  createdAt DateTime   @default(now())
  orgs      OrgUnit[]
  employees Employee[]
  assets    Asset[]
}

// 조직/하위조직 단위 (self-relation으로 계층 표현)
model OrgUnit {
  id        Int        @id @default(autoincrement())
  name      String
  companyId Int
  parentId  Int?
  sortOrder Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  company   OrgCompany @relation(fields: [companyId], references: [id])
  parent    OrgUnit?   @relation("OrgHierarchy", fields: [parentId], references: [id])
  children  OrgUnit[]  @relation("OrgHierarchy")
  members   Employee[] @relation("OrgMembers")
  assets    Asset[]

  @@unique([name, companyId])
}

model LicenseSeat {
  id          Int          @id @default(autoincrement())
  licenseId   Int
  key         String?      @unique
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  assignments Assignment[]
  license     License      @relation(fields: [licenseId], references: [id], onDelete: Cascade)

  @@index([licenseId])
}

model Assignment {
  id           Int                 @id @default(autoincrement())
  licenseId    Int
  employeeId   Int
  seatId       Int?
  assignedDate DateTime            @default(now())
  returnedDate DateTime?
  reason       String?
  createdAt    DateTime            @default(now())
  seat         LicenseSeat?        @relation(fields: [seatId], references: [id])
  employee     Employee            @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  license      License             @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  histories    AssignmentHistory[]

  @@index([licenseId])
  @@index([employeeId])
  @@index([seatId])
}

model AssignmentHistory {
  id           Int         @id @default(autoincrement())
  assignmentId Int?
  licenseId    Int
  employeeId   Int
  action       String
  reason       String?
  createdAt    DateTime    @default(now())
  assignment   Assignment? @relation(fields: [assignmentId], references: [id])

  @@index([employeeId])
  @@index([licenseId])
}

model LicenseGroup {
  id          Int                  @id @default(autoincrement())
  name        String               @unique
  description String?
  isDefault   Boolean              @default(false)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  members     LicenseGroupMember[]
}

model LicenseGroupMember {
  id             Int          @id @default(autoincrement())
  licenseGroupId Int
  licenseId      Int
  createdAt      DateTime     @default(now())
  license        License      @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  licenseGroup   LicenseGroup @relation(fields: [licenseGroupId], references: [id], onDelete: Cascade)

  @@unique([licenseGroupId, licenseId])
  @@index([licenseId])
}

model LicenseRenewalHistory {
  id         Int           @id @default(autoincrement())
  licenseId  Int
  fromStatus RenewalStatus
  toStatus   RenewalStatus
  actorType  String        @default("USER")
  actorId    Int?
  memo       String?
  changedAt  DateTime      @default(now())
  license    License       @relation(fields: [licenseId], references: [id], onDelete: Cascade)

  @@index([licenseId])
}

model LicenseOwner {
  id        Int      @id @default(autoincrement())
  licenseId Int
  userId    Int?
  orgUnitId Int?
  createdAt DateTime @default(now())
  license   License  @relation(fields: [licenseId], references: [id], onDelete: Cascade)

  @@index([licenseId])
}

model NotificationLog {
  id         Int      @id @default(autoincrement())
  licenseId  Int?
  assetId    Int?
  entityType String?                                // LICENSE | ASSET
  channel    String
  recipient  String
  status     String
  errorMsg   String?
  sentAt     DateTime @default(now())
  license    License? @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  asset      Asset?   @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([licenseId])
  @@index([assetId])
  @@index([sentAt])
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  entityType String
  entityId   Int
  action     String
  actor      String?
  actorType  String   @default("USER")
  actorId    Int?
  details    String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

enum Role {
  ADMIN
  USER
}

enum LicenseType {
  NO_KEY
  KEY_BASED
  VOLUME
}

enum PaymentCycle {
  MONTHLY
  YEARLY
}

enum Currency {
  KRW
  USD
  EUR
  JPY
  GBP
  CNY
}

enum MemberStatus {
  ACTIVE
  OFFBOARDING
  DELETED
}

enum RenewalStatus {
  BEFORE_RENEWAL
  IN_PROGRESS
  NOT_RENEWING
  RENEWED
}

// ── Phase 2: 자산 유형 확장 ──

enum AssetType {
  SOFTWARE    // 소프트웨어 라이선스
  CLOUD       // 클라우드·SaaS 구독
  HARDWARE    // 실물 자산
  DOMAIN_SSL  // 도메인·SSL 인증서
  CONTRACT    // 업체 계약 (유지보수, SLA, 외주 등)
  OTHER       // 기타
}

enum AssetStatus {
  IN_STOCK           // 재고 (미할당)
  IN_USE             // 사용 중
  INACTIVE           // 미사용·대기
  UNUSABLE           // 불용
  PENDING_DISPOSAL   // 폐기 대상
  DISPOSED           // 폐기 완료
}

model Asset {
  id              Int          @id @default(autoincrement())
  type            AssetType
  status          AssetStatus  @default(IN_STOCK)
  name            String                              // 자산명
  vendor          String?                             // 공급업체
  description     String?

  // 비용
  monthlyCost     Decimal?     @db.Decimal(12, 2)     // 월 환산 비용 (집계 기준)
  cost            Decimal?     @db.Decimal(12, 2)     // 실제 청구 금액
  currency        String?      @default("KRW")
  billingCycle    String?                             // MONTHLY | ANNUAL | ONE_TIME

  // 일정
  purchaseDate    DateTime?
  expiryDate      DateTime?
  renewalDate     DateTime?

  // 소유·배정
  companyId       Int?
  orgUnitId       Int?                                // 배정 부서
  assigneeId      Int?                                // 배정 조직원

  // 메타
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  createdBy       Int?                                // userId

  // 관계
  company           OrgCompany?       @relation(fields: [companyId], references: [id])
  orgUnit           OrgUnit?          @relation(fields: [orgUnitId], references: [id])
  assignee          Employee?         @relation(fields: [assigneeId], references: [id])
  hardwareDetail         HardwareDetail?
  cloudDetail            CloudDetail?
  contractDetail         ContractDetail?
  assignmentHistories    AssetAssignmentHistory[]
  notificationLogs       NotificationLog[]
  licenseLinks           AssetLicenseLink[]

  @@index([type])
  @@index([status])
  @@index([expiryDate])
  @@index([companyId])
}

model HardwareDetail {
  id              Int       @id @default(autoincrement())
  assetId         Int       @unique
  assetTag        String?                              // 내부 자산 식별번호
  deviceType      String?                              // Laptop / Desktop / Server / Network / Mobile / Other
  manufacturer    String?                              // 제조사 (Apple, Dell, Lenovo 등)
  model           String?                              // 모델명 (MacBook Pro M4 등)
  serialNumber    String?                              // 제조사 시리얼 넘버
  hostname        String?                              // 장비 이름
  macAddress      String?                              // MAC Address
  ipAddress       String?                              // 내부 IP Address
  os              String?                              // macOS / Windows / Linux
  osVersion       String?                              // OS 버전
  location        String?                              // 보관 위치
  cpu             String?                              // CPU 모델명 (Apple M4 Pro, Intel i7-13700 등)
  ram             String?                              // 메모리 (16GB, 32GB DDR5 등)
  storage         String?                              // 저장장치 (512GB SSD, 1TB NVMe 등)
  gpu             String?                              // 그래픽카드 (RTX 4060 등, 선택)
  displaySize     String?                              // 화면 크기 (14인치, 16.2인치 등, 노트북용)
  usefulLifeYears Int       @default(5)                // 내용연수 (감가상각, 기본 5년)

  // ── 보증/구매 관리 ──
  warrantyEndDate     DateTime?                        // 보증 만료일
  warrantyProvider    String?                          // 보증 업체 (제조사 AS센터, 리셀러 등)
  purchaseOrderNumber String?                          // PO 번호 (구매주문번호)
  invoiceNumber       String?                          // 인보이스 번호
  condition           String?                          // 상태 등급: A(최상) / B(양호) / C(보통) / D(불량)
  notes               String?                          // 비고/메모

  // ── 네트워크/인프라 ──
  secondaryIp         String?                          // 보조 IP (이중화, 관리용 등)
  subnetMask          String?                          // 서브넷 마스크 (255.255.255.0 등)
  gateway             String?                          // 게이트웨이
  vlanId              String?                          // VLAN ID
  dnsName             String?                          // DNS 호스트명 (FQDN)
  portCount           Int?                             // 포트 수 (스위치/라우터용)
  firmwareVersion     String?                          // 펌웨어 버전

  asset           Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model CloudDetail {
  id          Int      @id @default(autoincrement())
  assetId     Int      @unique
  platform    String?                                // AWS, GCP, Azure, Slack 등
  accountId   String?                                // 계정 ID / 이메일
  region      String?                                // 리전 (ap-northeast-2 등)
  seatCount   Int?                                   // 라이선스 수량

  // ── 서비스 분류 ──
  serviceCategory String?                            // IaaS / PaaS / SaaS / Security / Database / Storage / Network / Other
  resourceType    String?                            // EC2, S3, RDS, SecurityGroup, VPC, Lambda, ECS, ELB, CloudFront, Route53, IAM, Web/App, Database 등
  resourceId      String?                            // AWS 리소스 ID (i-xxx, sg-xxx, arn:aws:... 등)

  // ── 인프라 상세 ──
  instanceSpec      String?                          // 인스턴스 사양 (t4g.small, db.r6g.large 등)
  storageSize       String?                          // 저장 용량 (100GB, 1TB 등)
  endpoint          String?                          // 접속 URL/엔드포인트
  vpcId             String?                          // VPC ID
  availabilityZone  String?                          // 가용 영역 (ap-northeast-2a 등)

  // ── 관리 정보 ──
  adminEmail  String?                                // 관리자 이메일
  autoRenew   Boolean?                               // 자동 갱신 여부 (RI, Savings Plan 등)
  notes       String?                                // 비고

  asset       Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model ContractDetail {
  id              Int     @id @default(autoincrement())
  assetId         Int     @unique
  contractNumber  String?                              // 계약서 번호
  counterparty    String?                              // 계약 상대방 (업체명)
  contractType    String?                              // 유지보수 | SLA | 외주 | 기타
  autoRenew       Boolean @default(false)              // 자동 갱신 여부
  asset           Asset   @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model AssetAssignmentHistory {
  id           Int       @id @default(autoincrement())
  assetId      Int
  employeeId   Int
  action       String                                  // ASSIGNED | UNASSIGNED
  reason       String?
  performedBy  Int?                                    // userId (누가 할당/회수했는지)
  createdAt    DateTime  @default(now())
  asset        Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@index([employeeId])
}

// ── Phase 5: 자산-라이선스 연결 (M:N) ──

model AssetLicenseLink {
  id         Int      @id @default(autoincrement())
  assetId    Int
  licenseId  Int
  note       String?                                // 연결 메모 (설치 위치 등)
  createdAt  DateTime @default(now())
  createdBy  Int?                                   // userId
  asset      Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  license    License  @relation(fields: [licenseId], references: [id], onDelete: Cascade)

  @@unique([assetId, licenseId])
  @@index([assetId])
  @@index([licenseId])
}

// ── Phase 4: 자동 증적 시스템 ──

// 환율 이력 (매일 자정 업데이트)
model ExchangeRate {
  id         Int      @id @default(autoincrement())
  date       String                                  // YYYY-MM-DD
  currency   String                                  // USD, EUR, JPY, GBP, CNY
  rateToKRW  Decimal  @db.Decimal(15, 6)             // 1 currency = rateToKRW KRW
  source     String   @default("manual")             // manual | api
  createdAt  DateTime @default(now())

  @@unique([date, currency])
  @@index([date])
}

// 관리자 설정 카테고리 (구글드라이브 폴더 매핑)
model AssetCategory {
  id              Int       @id @default(autoincrement())
  name            String    @unique                  // 표시명
  code            String    @unique                  // 내부 코드 (LICENSE, EMPLOYEE 등)
  driveFolder     String?                            // 구글드라이브 폴더 ID
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  archives        Archive[]
}

// 증적 메타데이터
model Archive {
  id             Int            @id @default(autoincrement())
  yearMonth      String                               // YYYY-MM
  categoryId     Int?
  status         ArchiveStatus  @default(PENDING)
  trigger        String         @default("manual")   // manual | cron
  startDate      DateTime
  endDate        DateTime
  fileUrl        String?                              // 구글드라이브 URL
  excelUrl       String?
  csvUrl         String?
  createdBy      Int?                                 // userId (null = cron)
  createdAt      DateTime       @default(now())
  completedAt    DateTime?
  category       AssetCategory? @relation(fields: [categoryId], references: [id])
  logs           ArchiveLog[]
  data           ArchiveData[]

  @@index([yearMonth])
  @@index([status])
}

// 증적 작업 로그
model ArchiveLog {
  id        Int       @id @default(autoincrement())
  archiveId Int
  level     String    @default("info")               // info | warn | error
  message   String
  createdAt DateTime  @default(now())
  archive   Archive   @relation(fields: [archiveId], references: [id], onDelete: Cascade)

  @@index([archiveId])
}

// 증적 스냅샷 데이터 (JSON 직렬화)
model ArchiveData {
  id          Int      @id @default(autoincrement())
  archiveId   Int
  dataType    String                                  // licenses | employees | assignments | costs
  payload     Json                                    // 실제 스냅샷 데이터
  recordCount Int      @default(0)
  createdAt   DateTime @default(now())
  archive     Archive  @relation(fields: [archiveId], references: [id], onDelete: Cascade)

  @@index([archiveId])
  @@unique([archiveId, dataType])
}

enum ArchiveStatus {
  PENDING     // 대기 중
  RUNNING     // 실행 중
  COMPLETED   // 완료
  FAILED      // 실패
}
