// [2026-03-05] SQLite → PostgreSQL(Supabase) 전환
// [2026-03-04] MemberStatus/RenewalStatus enum 추가, OrgUnit sortOrder/updatedAt, Employee orgUnitId/status/offboardingUntil 통합,
//              License renewal 필드, LicenseRenewalHistory/LicenseOwner/NotificationLog 신규, AuditLog actorType/actorId, User mustChangePassword

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int       @id @default(autoincrement())
  username           String    @unique
  password           String
  role               Role      @default(USER)
  isActive           Boolean   @default(true)
  mustChangePassword Boolean   @default(false)
  createdAt          DateTime  @default(now())
  sessions           Session[]
}

model Session {
  id        String   @id
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model License {
  id                 Int                    @id @default(autoincrement())
  name               String                 @unique
  key                String?
  licenseType        LicenseType            @default(KEY_BASED)
  totalQuantity      Int
  price              Float?
  purchaseDate       DateTime
  expiryDate         DateTime?
  noticePeriodDays   Int?
  adminName          String?
  description        String?
  paymentCycle       PaymentCycle?
  quantity           Int?
  unitPrice          Float?
  currency           Currency               @default(KRW)
  exchangeRate       Float                  @default(1.0)
  isVatIncluded      Boolean                @default(false)
  totalAmountForeign Float?
  totalAmountKRW     Float?
  renewalDate        DateTime?
  renewalDateManual  DateTime?
  renewalStatus      RenewalStatus          @default(BEFORE_RENEWAL)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  assignments        Assignment[]
  groupMembers       LicenseGroupMember[]
  seats              LicenseSeat[]
  renewalHistories   LicenseRenewalHistory[]
  owners             LicenseOwner[]
  notificationLogs   NotificationLog[]
}

model Employee {
  id               Int           @id @default(autoincrement())
  name             String
  department       String
  email            String?       @unique
  title            String?
  companyId        Int?
  orgUnitId        Int?
  status           MemberStatus  @default(ACTIVE)
  offboardingUntil DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  assignments      Assignment[]
  company          OrgCompany?   @relation(fields: [companyId], references: [id])
  orgUnit          OrgUnit?      @relation("OrgMembers", fields: [orgUnitId], references: [id])

  @@index([orgUnitId])
  @@index([status])
}

// 회사 단위
model OrgCompany {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  createdAt DateTime   @default(now())
  orgs      OrgUnit[]
  employees Employee[]
}

// 조직/하위조직 단위 (self-relation으로 계층 표현)
model OrgUnit {
  id        Int        @id @default(autoincrement())
  name      String
  companyId Int
  parentId  Int?
  sortOrder Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  company   OrgCompany @relation(fields: [companyId], references: [id])
  parent    OrgUnit?   @relation("OrgHierarchy", fields: [parentId], references: [id])
  children  OrgUnit[]  @relation("OrgHierarchy")
  members   Employee[] @relation("OrgMembers")

  @@unique([name, companyId])
}

model LicenseSeat {
  id          Int          @id @default(autoincrement())
  licenseId   Int
  key         String?      @unique
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  assignments Assignment[]
  license     License      @relation(fields: [licenseId], references: [id], onDelete: Cascade)

  @@index([licenseId])
}

model Assignment {
  id           Int                 @id @default(autoincrement())
  licenseId    Int
  employeeId   Int
  seatId       Int?
  assignedDate DateTime            @default(now())
  returnedDate DateTime?
  reason       String?
  createdAt    DateTime            @default(now())
  seat         LicenseSeat?        @relation(fields: [seatId], references: [id])
  employee     Employee            @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  license      License             @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  histories    AssignmentHistory[]

  @@index([licenseId])
  @@index([employeeId])
  @@index([seatId])
}

model AssignmentHistory {
  id           Int         @id @default(autoincrement())
  assignmentId Int?
  licenseId    Int
  employeeId   Int
  action       String
  reason       String?
  createdAt    DateTime    @default(now())
  assignment   Assignment? @relation(fields: [assignmentId], references: [id])

  @@index([employeeId])
  @@index([licenseId])
}

model LicenseGroup {
  id          Int                  @id @default(autoincrement())
  name        String               @unique
  description String?
  isDefault   Boolean              @default(false)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  members     LicenseGroupMember[]
}

model LicenseGroupMember {
  id             Int          @id @default(autoincrement())
  licenseGroupId Int
  licenseId      Int
  createdAt      DateTime     @default(now())
  license        License      @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  licenseGroup   LicenseGroup @relation(fields: [licenseGroupId], references: [id], onDelete: Cascade)

  @@unique([licenseGroupId, licenseId])
  @@index([licenseId])
}

model LicenseRenewalHistory {
  id         Int           @id @default(autoincrement())
  licenseId  Int
  fromStatus RenewalStatus
  toStatus   RenewalStatus
  actorType  String        @default("USER")
  actorId    Int?
  memo       String?
  changedAt  DateTime      @default(now())
  license    License       @relation(fields: [licenseId], references: [id], onDelete: Cascade)

  @@index([licenseId])
}

model LicenseOwner {
  id        Int      @id @default(autoincrement())
  licenseId Int
  userId    Int?
  orgUnitId Int?
  createdAt DateTime @default(now())
  license   License  @relation(fields: [licenseId], references: [id], onDelete: Cascade)

  @@index([licenseId])
}

model NotificationLog {
  id        Int      @id @default(autoincrement())
  licenseId Int
  channel   String
  recipient String
  status    String
  errorMsg  String?
  sentAt    DateTime @default(now())
  license   License  @relation(fields: [licenseId], references: [id], onDelete: Cascade)

  @@index([licenseId])
  @@index([sentAt])
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  entityType String
  entityId   Int
  action     String
  actor      String?
  actorType  String   @default("USER")
  actorId    Int?
  details    String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

enum Role {
  ADMIN
  USER
}

enum LicenseType {
  NO_KEY
  KEY_BASED
  VOLUME
}

enum PaymentCycle {
  MONTHLY
  YEARLY
}

enum Currency {
  KRW
  USD
  EUR
  JPY
  GBP
  CNY
}

enum MemberStatus {
  ACTIVE
  OFFBOARDING
  DELETED
}

enum RenewalStatus {
  BEFORE_RENEWAL
  IN_PROGRESS
  NOT_RENEWING
  RENEWED
}
