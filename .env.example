# ============================================================
# License Manager — 환경변수 템플릿
# 이 파일을 복사하여 .env 로 저장한 뒤 실제 값을 입력하세요.
# cp .env.example .env
# ============================================================

# --- 필수 ---
DATABASE_URL=file:./dev.db
CRON_SECRET=your-cron-secret-here

# --- 인증 ---
# HTTPS 종료점(리버스 프록시) 뒤에서 운영 시 true, 폐쇄망 HTTP 직접 접근 시 false
SECURE_COOKIE=false

# --- 알림 (선택) ---
SLACK_WEBHOOK_URL=

# SMTP (이메일 알림)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=false
