# License Manager — 환경변수 설정
# 이 파일을 .env로 복사하고 실제 값으로 수정하세요.

# PostgreSQL 연결 문자열
# docker-compose 사용: postgresql://license_manager:license_manager_pass@postgres:5432/license_manager
# EC2 호스트: postgresql://license_manager:license_manager_pass@172.17.0.1:5432/license_manager
# 로컬 개발: postgresql://license_manager:license_manager_pass@localhost:5432/license_manager
DATABASE_URL=postgresql://license_manager:license_manager_pass@postgres:5432/license_manager

# Secure Cookie (HTTP 배포 시 false, HTTPS 배포 시 true)
SECURE_COOKIE=false

# Node 환경 (development 또는 production)
NODE_ENV=production

# Seed 관련 (개발/테스트 시에만 사용)
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=changeme123
